{
  "name": "jan-wennrich/bgg-portfolio-generator",
  "description": "Generates static portfolio websites from BoardGameGeek accounts",
  "license": "GPL-3.0-or-later",
  "type": "project",
  "require": {
    "php": "^8.4",
    "ext-mbstring": "*",
    "composer-runtime-api": "^2.2",
    "guzzlehttp/guzzle": "^7.10",
    "guzzlehttp/psr7": "^2.8",
    "jan-wennrich/bgg-api": "^0.2.0",
    "php-di/php-di": "^7.1.1",
    "ramsey/collection": "^2.1.1",
    "symfony/console": "^8.0.7",
    "twig/twig": "^3.23.0"
  },
  "require-dev": {
    "captainhook/captainhook": "^5.28.5",
    "ergebnis/composer-normalize": "^2.50.0",
    "friendsofphp/php-cs-fixer": "^3.94.2",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.1.40",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "rector/rector": "^2.3.8",
    "shipmonk/composer-dependency-analyser": "^1.8.4"
  },
  "minimum-stability": "stable",
  "autoload": {
    "psr-4": {
      "JanWennrich\\BoardGames\\": "src/"
    }
  },
  "bin": [
    "bin/bgg-portfolio-generator.php"
  ],
  "config": {
    "allow-plugins": {
      "ergebnis/composer-normalize": true,
      "php-http/discovery": true,
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "test": [
      "@composer normalize --dry-run",
      "@composer validate --strict",
      "@php vendor/bin/composer-dependency-analyser",
      "@php vendor/bin/phpstan",
      "@php vendor/bin/rector --dry-run",
      "@php vendor/bin/php-cs-fixer check"
    ]
  }
}
